{
  "name": "mawejs",
  "version": "0.25.0",
  "description": "Editor for writers.",
  "author": "Markus Koskimies <mkoskim@gmail.com>",
  "scripts": {
    "dev": "electron-vite -w dev",
    "build": "npm run vite-build && electron-builder",
    "vite-build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "node test/run.mjs",
    "test:update": "node test/run.mjs --update",
    "test:load": "node test/run.mjs test/test_load.js",
    "test:roundtrip": "node test/run.mjs test/test_roundtrip.js",
    "audit": "npm audit --omit=dev",
    "fresh": "rm -rf dist build node_modules package-lock.json && npm install",
    "fix": "sudo chown root node_modules/electron/dist/chrome-sandbox && sudo chmod 4755 node_modules/electron/dist/chrome-sandbox"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@hello-pangea/dnd": "^18.0.1",
    "electron-devtools-installer": "^4.0.0",
    "electron-localshortcut": "^3.2.1",
    "electron-window-state": "^5.0.3",
    "immer": "^11.1.4",
    "is-gzip": "^2.0.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.9",
    "notistack": "^3.0.2",
    "pako": "^2.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-infinite-scroll-component": "7.2.0",
    "recharts": "^3.8.1",
    "slate": "^0.124.1",
    "slate-dom": "^0.124.1",
    "slate-history": "^0.113.1",
    "slate-react": "^0.124.0",
    "stream": "^0.0.3",
    "use-immer": "^0.11.0",
    "uuid": "^14.0.0",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "node": "^22.22.2"
  },
  "main": "./out/main/index.js",
  "build": {
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      "examples/tutorial/*"
    ],
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
